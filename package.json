{
  "name": "pulsedesignsystem",
  "version": "0.1.0",
  "private": true,
  "description": "Pulse Design System monorepo: tokens (synced from Figma) + React Native components + Storybook",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "sync": "pnpm --filter @pulse/tokens sync",
    "storybook": "pnpm --filter @pulse/storybook dev",
    "build-storybook": "pnpm --filter @pulse/storybook build"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.12.0"
}
